{% if profile.nginx.ssl_enabled %}
server {
    server_name {{ profile.nginx.domain }};
    listen 80;
    return 301 https://$server_name$request_uri;
}

server {
    server_name {{ profile.nginx.domain }};
    listen 443 ssl;
    ssl_certificate {{ profile.nginx.ssl_certificate }};
    ssl_certificate_key {{ profile.nginx.ssl_certificate_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:5m;
    add_header Strict-Transport-Security "max-age=15768000" always;
    add_header X-Frame-Options "SAMEORIGIN";
    add_header 'Access-Control-Allow-Origin' '*';
    add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, OPTIONS';
    add_header 'Access-Control-Allow-Headers' 'Authorization, Content-Type';
{% else %}
server {
    server_name {{ profile.nginx.domain }};
    listen 80;
{% endif %}

    location / {
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Server $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Host $http_host;
        proxy_pass http://localhost:{{ profile.ports.web }}/;
        proxy_http_version 1.1;
    }

    location /webui {
        proxy_pass http://localhost:{{ profile.ports.web }}/webui;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /webui/zkau/comet {
        proxy_pass http://localhost:{{ profile.ports.web }}/webui/zkau/comet;
        proxy_http_version 1.1;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $http_host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_read_timeout 300;
    }

    client_max_body_size 20M;
}
